# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/cuadre_caja"
DIRECT_URL="postgresql://user:password@localhost:5432/cuadre_caja"

# Autenticación
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Inicialización del sistema
INIT_SECRET="your-init-secret-for-superadmin"

# Opcional: Variables de desarrollo
NODE_ENV="development"

# Activación de usuarios automaticamente al crearse
ACTIVATION_JWT_SECRET="your-activation-jwt-secret"

# Invitación / restablecimiento de usuarios del negocio (JWT en enlace; invitación 4h, reset 1h)
USER_ACCOUNT_JWT_SECRET="your-user-account-jwt-secret-min-32-chars"
N8N_USER_INVITE_WEBHOOK="https://n8n.example.com/webhook/user-invite/"
N8N_USER_INVITE_API_KEY="your-query-token"
N8N_USER_PASSWORD_RESET_WEBHOOK="https://n8n.example.com/webhook/user-password-reset/"
N8N_USER_PASSWORD_RESET_API_KEY="your-query-token"

# Purga vía API externa (POST .../purge-expired-freemium-landing-negocios, header x-api-key)
PURGE_LANDING_NEGOCIOS_API_KEY="your-purge-landing-negocios-api-key"